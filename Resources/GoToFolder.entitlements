<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        App Sandbox is disabled so the app can freely launch other
        applications (terminals) and run AppleScript against Finder.
        If you plan to submit to the Mac App Store, you must enable the
        sandbox and use XPC/URL-scheme approaches instead.
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Allows sending Apple Events to other apps (Finder, Terminal, etc.) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
